    {
      "parameters": {
        "promptType": "define",
        "text": "=Teacher Query:\n{{$('Webhook').first().json.body.prompt}}\n\nBelow are all retrieved syllabus chunks:\n\n{{$json}}\n\nSelect the 5 most relevant chunks for answering the teacher query.\n\nReturn ONLY valid JSON in this exact format:\n\n{\n  \"top_chunks\": [\n    {\n      \"text\": \"chunk 1 here\"\n    },\n    {\n      \"text\": \"chunk 2 here\"\n    },\n    {\n      \"text\": \"chunk 3 here\"\n    },\n    {\n      \"text\": \"chunk 4 here\"\n    },\n    {\n      \"text\": \"chunk 5 here\"\n    }\n  ]\n}",
        "batching": {}
      },
