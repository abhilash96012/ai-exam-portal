    {
      "parameters": {
        "promptType": "define",
        "text": "=Expand the following teacher query into 5 different search queries.\n\nTeacher Query:\n{{$json.body.prompt}}\n\nReturn only JSON in this format:\n{\n  \"queries\": [\n    \"...\",\n    \"...\",\n    \"...\",\n    \"...\",\n    \"...\"\n  ]\n}",
        "batching": {}
      },
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.9,
      "position": [
        -1024,
        160
      ],
      "id": "118522e5-3f17-4a9e-bec3-d62a39372d62",
      "name": "Expand Queries via Ollama"
    },
    {
      "parameters": {
        "jsCode": "const responseText = $input.first().json.text;\ntry {\n  let text = responseText;\n  // Remove markdown formatting if present\n  if (text.indexOf('```') !== -1) {\n    text = text.replace(/```json\\n/g, '').replace(/```/g, '').trim();\n  }\n  const parsed = JSON.parse(text);\n  return (parsed.queries || []).map(q => ({ json: { query: q } }));\n} catch (e) {\n  // Fallback to original prompt if parsing fails\n  return [{ json: { query: $('Webhook').first().json.body.prompt } }];\n}"
      },
      "type": "n8n-nodes-base.code",
