    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\n\nconst text = input.text || \"\";\n\nconst chunkSize = 1000;\nconst overlap = 100;\n\nconst result = [];\n\nfor (let i = 0; i < text.length; i += (chunkSize - overlap)) {\n  result.push({\n    json: {\n      department: input.department,\n      year: input.year,\n      subject: input.subject,\n      text: text.slice(i, i + chunkSize)\n    }\n  });\n}\n\nreturn result;"
      },
